{
    "github.copilot.nextEditSuggestions.enabled": true,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "debug.onTaskErrors": "debugAnyway",
    "code-runner.runInTerminal": true,
    "C_Cpp.intelliSenseEngine": "default",
    "editor.formatOnType": true,
    "C_Cpp.vcFormat.newLine.scopeBracesOnSeparateLines": true,
    "editor.formatOnPaste": true,
    "workbench.editor.empty.hint": "hidden",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",
    "workbench.colorTheme": "Visual Studio Dark - C++",
    "editor.inlineSuggest.enabled": false,
    "workbench.iconTheme": "fira-code-material-minimal",
    "clangd.detectExtensionConflicts": false,
    "C_Cpp.default.intelliSenseMode": "macos-gcc-x64",
    "editor.quickSuggestions": {
        "comments": "on",
        "strings": "on",
        "other": "on"
    },
    "editor.suggestSelection": "first",
    "configurations": [
    
    ]
}
